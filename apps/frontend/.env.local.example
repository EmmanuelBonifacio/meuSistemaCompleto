# =============================================================================
# .env.local.example
# =============================================================================
# COMO USAR:
#   1. Copie este arquivo: cp .env.local.example .env.local
#   2. Preencha os valores com as configurações do seu ambiente
#   3. NUNCA commite o .env.local para o Git (está no .gitignore)
#
# PREFIXO NEXT_PUBLIC_:
#   Variáveis com este prefixo são expostas ao browser (bundle JS do cliente).
#   Use APENAS para dados não sensíveis (URLs de API públicas, feature flags, etc.)
#   Variáveis SEM o prefixo só existem no servidor Node.js do Next.js.
# =============================================================================

# URL base do Backend (Node.js/Fastify)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Chave secreta para assinar cookies de sessão no servidor Next.js
# NUNCA use com prefixo NEXT_PUBLIC_ — é um segredo!
# Gere uma string aleatória forte: openssl rand -base64 32
NEXTAUTH_SECRET=substitua-por-uma-string-aleatoria-forte-aqui

# URL base do frontend (necessário para callbacks de autenticação)
NEXTAUTH_URL=http://localhost:3001

# Ambiente de execução
NODE_ENV=development

# =============================================================================
# Módulo SalesWpp (Vendas via WhatsApp)
# =============================================================================
# Número padrão do WhatsApp para checkout (sobreposto pelo cadastro do tenant)
# Formato: código do país + DDD + número (sem +, espaços ou traços)
# Exemplo para Brasil: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=""
