# =============================================================================
# .gitignore  (monorepo root)
# =============================================================================

# ─── Variáveis de ambiente (NUNCA comitar!) ──────────────────────────────────
.env
.env.local
.env.production

# ─── Certificados SSL (gerados pelo scripts/setup.sh) ────────────────────────
docker/nginx/certs/*.pem

# ─── Dependências ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build outputs ───────────────────────────────────────────────────────────
dist/
**/dist/
.next/
**/.next/
out/
**/out/

# ─── Uploads de usuários (gerenciados via volume Docker em produção) ─────────
uploads/

# ─── Prisma ──────────────────────────────────────────────────────────────────
# O cliente gerado é reproduzível via `prisma generate` — não comitar
apps/backend/node_modules/.prisma/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Certificados SSL locais ─────────────────────────────────────────────────
docker/nginx/certs/*.pem
docker/nginx/certs/*.key
docker/nginx/certs/*.crt

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.swp
*.swo

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
