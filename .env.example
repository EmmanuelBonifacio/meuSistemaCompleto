# =============================================================================
# .env.example
# =============================================================================
# Este arquivo serve como TEMPLATE para as variáveis de ambiente.
# COMO USAR:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores no arquivo .env com suas configurações reais
#   3. NUNCA commite o arquivo .env no Git (ele já está no .gitignore)
#
# POR QUE VARIÁVEIS DE AMBIENTE?
#   Separa configuração de código. A mesma aplicação pode rodar em
#   desenvolvimento, staging e produção com configurações diferentes,
#   sem precisar alterar nenhuma linha de código.
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------

# URL de conexão completa usada pelo Prisma ORM
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
# ATENÇÃO: O schema=public aqui se refere ao schema PADRÃO para as migrations
# do Prisma. O schema de cada tenant é definido dinamicamente no código.
DATABASE_URL="postgresql://saas_user:saas_password@localhost:5433/saas_multitenant_db?schema=public"

# Credenciais individuais (usadas pelo docker-compose)
POSTGRES_USER="saas_user"
POSTGRES_PASSWORD="saas_password"
POSTGRES_DB="saas_multitenant_db"
POSTGRES_PORT="5433"

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO JWT
# -----------------------------------------------------------------------------

# Segredo para assinar os tokens JWT.
# REGRA DE OURO: Use uma string aleatória longa (mínimo 32 caracteres) em produção!
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="TROQUE_ISSO_POR_UMA_STRING_SECRETA_LONGA_E_ALEATORIA"

# Tempo de expiração do token de acesso (access token)
# Valores: "15m" = 15 minutos, "1h" = 1 hora, "7d" = 7 dias
JWT_ACCESS_TOKEN_EXPIRATION="1h"

# Tempo de expiração do refresh token (usado para renovar o access token)
JWT_REFRESH_TOKEN_EXPIRATION="7d"

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------

# Porta em que o servidor Fastify vai escutar
PORT=3000

# Ambiente da aplicação: development | production | test
NODE_ENV="development"

# -----------------------------------------------------------------------------
# PGADMIN (apenas para desenvolvimento local)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL="admin@admin.com"
PGADMIN_PASSWORD="admin"
