# =============================================================================
# .env.example  (monorepo root)
# =============================================================================
# Copie para .env e preencha os valores ANTES de rodar docker compose.
# NUNCA comite o .env real no repositório.
# =============================================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=saas_prod

# ─── Backend (apps/backend) ──────────────────────────────────────────────────
# URL de conexão com o banco (em Docker usa hostname "postgres")
DATABASE_URL=postgresql://postgres:TROQUE_POR_SENHA_FORTE@postgres:5432/saas_prod

# Segredo JWT — mínimo 32 caracteres, gerado aleatoriamente
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_POR_SEGREDO_ALEATORIO_MINIMO_32_CHARS
JWT_ACCESS_TOKEN_EXPIRATION=1h

# URL do frontend (usada pelo CORS do backend em produção)
FRONTEND_URL=https://app.seudominio.com

# Caminho onde os uploads serão salvos dentro do container
UPLOADS_DIR=/uploads

# ─── Frontend (apps/frontend) ────────────────────────────────────────────────
# URL da API — usada pelo browser para chamadas ao backend
NEXT_PUBLIC_API_URL=https://api.seudominio.com

# NextAuth — necessário se usar next-auth
NEXTAUTH_URL=https://app.seudominio.com
NEXTAUTH_SECRET=TROQUE_POR_OUTRO_SEGREDO_ALEATORIO

# ─── pgAdmin (apenas desenvolvimento) ────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
